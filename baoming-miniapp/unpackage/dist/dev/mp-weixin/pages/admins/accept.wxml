<view class="page data-v-7a612d4a"><block wx:if="{{loading}}"><view class="card data-v-7a612d4a"><view class="empty-state data-v-7a612d4a"><text class="empty-icon data-v-7a612d4a">⏳</text><text class="empty-text data-v-7a612d4a">处理中...</text></view></view></block><block wx:else><block wx:if="{{error}}"><view class="card data-v-7a612d4a"><view class="empty-state data-v-7a612d4a"><text class="empty-icon data-v-7a612d4a">❌</text><text class="empty-text data-v-7a612d4a">{{error}}</text></view><button data-event-opts="{{[['tap',[['goHome',['$event']]]]]}}" class="btn-outline btn-block data-v-7a612d4a" bindtap="__e">返回首页</button></view></block><block wx:else><block wx:if="{{accepted}}"><view class="card data-v-7a612d4a"><view class="empty-state data-v-7a612d4a"><text class="empty-icon data-v-7a612d4a">✅</text><text class="empty-text data-v-7a612d4a">{{"已成功成为「"+activityName+"」的管理员"}}</text><text class="empty-sub data-v-7a612d4a">你可以查看和管理该活动的报名数据</text></view><button data-event-opts="{{[['tap',[['goRecords',['$event']]]]]}}" class="btn-primary btn-block data-v-7a612d4a" bindtap="__e">查看我管理的活动</button></view></block><block wx:else><view class="card data-v-7a612d4a"><view class="invite-card data-v-7a612d4a"><text class="invite-icon data-v-7a612d4a">📋</text><text class="invite-title data-v-7a612d4a">管理员邀请</text><text class="invite-desc data-v-7a612d4a">{{"你被邀请成为「"+activityName+"」的管理员"}}</text><text class="invite-info data-v-7a612d4a">接受后，你将可以： 查看报名数据 · 导出CSV · 删除报名记录</text></view><button class="btn-primary btn-block data-v-7a612d4a" loading="{{submitting}}" data-event-opts="{{[['tap',[['handleAccept',['$event']]]]]}}" bindtap="__e"> 接受邀请 </button><button data-event-opts="{{[['tap',[['goHome',['$event']]]]]}}" class="btn-outline btn-block data-v-7a612d4a" style="margin-top:16rpx;" bindtap="__e"> 拒绝 </button></view></block></block></block></view>