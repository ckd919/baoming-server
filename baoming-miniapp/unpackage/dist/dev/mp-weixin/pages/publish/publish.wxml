<view class="page data-v-177a8126"><block wx:if="{{activity}}"><view class="status-card data-v-177a8126"><text class="status-icon data-v-177a8126">{{activity.status==='published'?'✅':'📦'}}</text><text class="status-text data-v-177a8126">{{activity.status==='published'?'已发布':'待发布'}}</text><view class="stats data-v-177a8126"><view class="stat-item data-v-177a8126"><text class="stat-val data-v-177a8126">{{$root.g0}}</text><text class="stat-lbl data-v-177a8126">字段</text></view><view class="stat-item data-v-177a8126"><text class="stat-val data-v-177a8126">{{activity.submissionCount||0}}</text><text class="stat-lbl data-v-177a8126">已报名</text></view><view class="stat-item data-v-177a8126"><text class="stat-val data-v-177a8126">{{activity.maxParticipants||'∞'}}</text><text class="stat-lbl data-v-177a8126">上限</text></view></view></view></block><block wx:if="{{activity}}"><view class="card data-v-177a8126"><text class="card-title data-v-177a8126">📤 分享报名表</text><text class="card-desc data-v-177a8126">通过微信分享卡片，好友点击直接在小程序内填写</text><button class="wx-share-btn data-v-177a8126" open-type="share"><text class="data-v-177a8126">💬 分享给微信好友</text></button></view></block><block wx:if="{{activity}}"><view class="card data-v-177a8126"><text class="card-title data-v-177a8126">🔒 分享权限</text><text class="card-desc data-v-177a8126">控制谁可以将此报名表分享给他人</text><view class="share-level-list data-v-177a8126"><block wx:for="{{shareLevels}}" wx:for-item="opt" wx:for-index="__i0__" wx:key="value"><view data-event-opts="{{[['tap',[['setShareLevel',['$0'],[[['shareLevels','value',opt.value,'value']]]]]]]}}" class="{{['share-level-item','data-v-177a8126',(shareLevel===opt.value)?'selected':'']}}" bindtap="__e"><view class="sl-left data-v-177a8126"><radio checked="{{shareLevel===opt.value}}" color="#FF6B35" class="data-v-177a8126"></radio><view class="sl-info data-v-177a8126"><text class="sl-label data-v-177a8126">{{opt.label}}</text><text class="sl-desc data-v-177a8126">{{opt.desc}}</text></view></view></view></block></view><text class="hint data-v-177a8126" style="margin-top:16rpx;">{{''+shareLevelHint+''}}</text></view></block><block wx:if="{{activity}}"><view class="card data-v-177a8126"><text class="card-title data-v-177a8126">🔗 群限制转发</text><text class="card-desc data-v-177a8126">开启后，表单分享到群后群成员无法再次转发，防止扩散到群外</text><view class="flex-row data-v-177a8126"><text class="data-v-177a8126">禁止群成员转发</text><switch checked="{{groupRestricted}}" color="#FF6B35" data-event-opts="{{[['change',[['toggleGroupRestricted',['$event']]]]]}}" bindchange="__e" class="data-v-177a8126"></switch></view><text class="hint data-v-177a8126" style="margin-top:12rpx;">{{''+(groupRestricted?'🔒 群成员无法转发此表单到其他群或个人':'📤 群成员可以自由转发此表单')+''}}</text></view></block><block wx:if="{{activity&&activity.status!=='published'}}"><view class="card data-v-177a8126"><button data-event-opts="{{[['tap',[['publishNow',['$event']]]]]}}" class="btn-primary btn-block data-v-177a8126" bindtap="__e"> 🚀 立即发布 </button></view></block><block wx:if="{{activity}}"><view class="card data-v-177a8126"><button data-event-opts="{{[['tap',[['previewForm',['$event']]]]]}}" class="btn-outline btn-block data-v-177a8126" bindtap="__e">👁 预览报名表</button></view></block></view>