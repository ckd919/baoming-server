pt.value}}" color="#D4720D" class="data-v-177a8126"></radio><view class="sl-info data-v-177a8126"><text class="sl-label data-v-177a8126">{{opt.label}}</text><text class="sl-desc data-v-177a8126">{{opt.desc}}</text></view></view></view></block></view><text class="hint data-v-177a8126" style="margin-top:16rpx;">{{''+shareLevelHint+''}}</text></view></block><block wx:if="{{activity}}"><view class="card data-v-177a8126"><block wx:if="{{activity.status!=='published'}}"><button data-event-opts="{{[['tap',[['publishNow',['$event']]]]]}}" class="btn-primary btn-block data-v-177a8126" bindtap="__e"> 🚀 立即发布 </button></block><block wx:else><button data-event-opts="{{[['tap',[['unpublish',['$event']]]]]}}" class="btn-block btn-secondary data-v-177a8126" bindtap="__e"> 取消发布 </button></block></view></block><block wx:if="{{activity}}"><view class="card data-v-177a8126"><button data-event-opts="{{[['tap',[['previewForm',['$event']]]]]}}" class="btn-outline btn-block data-v-177a8126" bindtap="__e">👁 预览报名表</button></view></block></view>