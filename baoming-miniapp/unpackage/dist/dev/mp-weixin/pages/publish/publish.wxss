
.page.data-v-177a8126 { padding: 20rpx; padding-bottom: 40rpx;
}
.status-card.data-v-177a8126 {
  text-align: center; background: #fff; border-radius: 20rpx;
  padding: 40rpx; margin-bottom: 20rpx;
}
.status-icon.data-v-177a8126 { font-size: 80rpx;
}
.status-text.data-v-177a8126 { display: block; font-size: 32rpx; font-weight: 600; margin: 12rpx 0 20rpx;
}
.stats.data-v-177a8126 { display: flex; justify-content: center; gap: 40rpx;
}
.stat-val.data-v-177a8126 { display: block; font-size: 40rpx; font-weight: 700; color: #FF6B35;
}
.stat-lbl.data-v-177a8126 { font-size: 22rpx; color: #999;
}
.card-title.data-v-177a8126 { font-size: 30rpx; font-weight: 600; display: block; margin-bottom: 8rpx;
}
.card-desc.data-v-177a8126 { font-size: 24rpx; color: #999; display: block; margin-bottom: 20rpx;
}
.url-box.data-v-177a8126 {
  display: flex; align-items: center; gap: 12rpx;
  background: #F0F0F2; padding: 16rpx; border-radius: 12rpx;
  word-break: break-all;
}
.url-text.data-v-177a8126 { flex: 1; font-size: 24rpx; color: #666;
}
.qr-wrap.data-v-177a8126 { text-align: center; margin: 24rpx 0;
}
.hint.data-v-177a8126 { font-size: 24rpx; color: #999; display: block;
}

/* 分享等级选择 */
.share-level-list.data-v-177a8126 {
  display: flex; flex-direction: column; gap: 12rpx;
}
.share-level-item.data-v-177a8126 {
  padding: 20rpx 24rpx;
  background: #F8F8FA;
  border-radius: 16rpx;
  border: 3rpx solid transparent;
  transition: all 0.2s;
}
.share-level-item.selected.data-v-177a8126 {
  background: #FFF5F0;
  border-color: #FF6B35;
}
.sl-left.data-v-177a8126 { display: flex; align-items: flex-start; gap: 16rpx;
}
.sl-label.data-v-177a8126 { font-size: 28rpx; font-weight: 500; display: block;
}
.sl-desc.data-v-177a8126 { font-size: 22rpx; color: #999; display: block; margin-top: 4rpx;
}
.btn-sm.data-v-177a8126 { padding: 12rpx 20rpx; font-size: 24rpx; flex-shrink: 0;
}
.btn-secondary.data-v-177a8126 {
  background: #f5f5f5; color: #999; border: none;
  border-radius: 44rpx; font-size: 32rpx; font-weight: 600;
  padding: 24rpx 40rpx;
}
.stop-row.data-v-177a8126 { display: flex; gap: 16rpx; margin-top: 12rpx;
}
.wx-share-btn.data-v-177a8126 {
  width: 100%; height: 88rpx;
  background: #07C160; color: #fff;
  border: none; border-radius: 44rpx;
  font-size: 30rpx; font-weight: 600;
  display: flex; align-items: center; justify-content: center;
}

