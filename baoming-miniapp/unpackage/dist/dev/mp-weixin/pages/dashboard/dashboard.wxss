
.page.data-v-a09b2520 { padding-bottom: 40rpx;
}
.header.data-v-a09b2520 {
  background: linear-gradient(160deg, #FF6B35, #E55A2B);
  color: #fff; padding: 40rpx 32rpx 30rpx;
}
.greeting.data-v-a09b2520 { font-size: 24rpx; opacity: 0.8;
}
.title.data-v-a09b2520 { font-size: 40rpx; font-weight: 700; margin-top: 8rpx;
}
.search-bar.data-v-a09b2520 {
  display: flex; align-items: center; gap: 12rpx;
  background: #fff; padding: 8rpx 20rpx; margin: 20rpx;
  border-radius: 40rpx;
}
.search-bar input.data-v-a09b2520 { flex: 1; font-size: 28rpx; height: 64rpx;
}
.tab-scroll.data-v-a09b2520 {
  white-space: nowrap; padding: 0 20rpx 16rpx;
  background: #fff; border-bottom: 2rpx solid #F0F0F2;
}
.tab-item.data-v-a09b2520 {
  display: inline-block; padding: 16rpx 28rpx;
  font-size: 28rpx; color: #666;
}
.tab-item.active.data-v-a09b2520 { color: #FF6B35; font-weight: 600;
}
.list-wrap.data-v-a09b2520 { padding: 0 20rpx;
}
.activity-card.data-v-a09b2520 {
  background: #fff; border-radius: 20rpx;
  padding: 28rpx; margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}
.card-top.data-v-a09b2520 { display: flex; justify-content: space-between; align-items: flex-start;
}
.card-info.data-v-a09b2520 { flex: 1;
}
.activity-name.data-v-a09b2520 { font-size: 32rpx; font-weight: 600;
}
.card-meta.data-v-a09b2520 { display: flex; align-items: center; gap: 12rpx; margin-top: 8rpx;
}
.meta-text.data-v-a09b2520 { font-size: 24rpx; color: #999;
}
.progress-bar.data-v-a09b2520 {
  height: 6rpx; background: #F0F0F2; border-radius: 3rpx;
  margin: 16rpx 0; overflow: hidden;
}
.progress-fill.data-v-a09b2520 {
  height: 6rpx; background: linear-gradient(90deg, #FF6B35, #FF8C5A);
  border-radius: 3rpx; transition: width 0.5s;
}
.card-info-row.data-v-a09b2520 {
  display: flex; flex-wrap: wrap; gap: 16rpx; font-size: 24rpx; color: #999;
  margin-bottom: 16rpx;
}
.card-actions.data-v-a09b2520 {
  display: flex; flex-wrap: wrap; gap: 10rpx;
  padding-top: 18rpx; border-top: 2rpx solid #F5F5F7;
}
.card-actions .btn-sm.data-v-a09b2520 { flex-shrink: 0;
}
.btn-delete.data-v-a09b2520 { background: none; border: none; font-size: 24rpx; padding: 8rpx 12rpx; color: #999;
}

/* FAB */
.fab.data-v-a09b2520 {
  position: fixed; bottom: 120rpx; right: 40rpx;
  width: 100rpx; height: 100rpx;
  background: linear-gradient(135deg, #FF6B35, #FF8C5A);
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(212, 114, 13, 0.35);
  z-index: 50;
}
.fab-icon.data-v-a09b2520 { font-size: 56rpx; color: #fff; line-height: 1;
}

