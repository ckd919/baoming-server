
.login-page.data-v-b237504c {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: linear-gradient(160deg, #FF6B35, #E55A2B, #2D1F18);
  padding: 60rpx;
}
.login-logo.data-v-b237504c {
  width: 140rpx; height: 140rpx;
  background: rgba(255,255,255,0.18);
  border-radius: 28rpx;
  display: flex; align-items: center; justify-content: center;
  font-size: 64rpx; margin-bottom: 20rpx;
  overflow: hidden;
}
.avatar-img.data-v-b237504c { width: 100%; height: 100%; border-radius: 28rpx;
}
.login-title.data-v-b237504c { font-size: 44rpx; font-weight: 700; color: #fff;
}
.login-desc.data-v-b237504c { font-size: 26rpx; color: rgba(255,255,255,0.7); margin-bottom: 48rpx;
}
.login-card.data-v-b237504c {
  width: 100%; background: #fff; border-radius: 24rpx;
  padding: 48rpx 36rpx 36rpx; box-shadow: 0 16rpx 64rpx rgba(0,0,0,0.15);
}
.wx-info.data-v-b237504c { display: flex; align-items: center; gap: 20rpx; margin-bottom: 32rpx;
}
.avatar-btn.data-v-b237504c {
  width: 120rpx; height: 120rpx; border-radius: 50%;
  border: none; background: #F5F3F0; padding: 0;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0; overflow: hidden;
}
.wx-avatar.data-v-b237504c { width: 120rpx; height: 120rpx; border-radius: 50%;
}
.avatar-placeholder.data-v-b237504c { font-size: 44rpx;
}
.wx-name-box.data-v-b237504c { flex: 1;
}
.nickname-input.data-v-b237504c {
  width: 100%; height: 80rpx; padding: 0 20rpx;
  background: #F9F8F6; border-radius: 12rpx; font-size: 30rpx;
}
.wx-tip.data-v-b237504c { font-size: 22rpx; color: #999; margin-top: 6rpx; display: block;
}
.agree-row.data-v-b237504c {
  display: flex; align-items: center; gap: 4rpx;
  padding: 8rpx 0; margin-bottom: 20rpx;
}
.agree-text.data-v-b237504c { font-size: 24rpx; color: #999;
}
.agree-link.data-v-b237504c { font-size: 24rpx; color: #FF6B35;
}
/* 微信授权登录按钮 */
.wx-auth-btn.data-v-b237504c {
  width: 100%; height: 96rpx;
  background: #07C160; color: #fff;
  border: none; border-radius: 48rpx;
  font-size: 32rpx; font-weight: 600;
  display: flex; align-items: center; justify-content: center; gap: 12rpx;
}
.wx-auth-btn[disabled].data-v-b237504c { opacity: 0.5;
}
.wx-icon.data-v-b237504c { font-size: 40rpx;
}
.bottom-tip.data-v-b237504c { display: block; text-align: center; font-size: 24rpx; color: #999; margin-top: 12rpx;
}
.dev-toggle.data-v-b237504c { text-align: center; font-size: 22rpx; color: #ccc; margin-top: 24rpx; padding: 12rpx;
}
.form-group.data-v-b237504c { margin-bottom: 24rpx;
}
.form-label.data-v-b237504c { display: block; font-size: 28rpx; font-weight: 500; margin-bottom: 12rpx;
}
.back-link.data-v-b237504c { text-align: center; margin-top: 24rpx; padding: 12rpx;
}
.back-link text.data-v-b237504c { font-size: 26rpx; color: #999;
}

