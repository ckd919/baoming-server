<view class="login-page data-v-b237504c"><view class="login-logo data-v-b237504c"><block wx:if="{{avatarUrl}}"><image class="avatar-img data-v-b237504c" src="{{avatarUrl}}"></image></block><block wx:else><text class="data-v-b237504c">🐻</text></block></view><view class="login-title data-v-b237504c">熊熊活动助手</view><view class="login-desc data-v-b237504c">活动预约 · 培训报名 · 场馆预约</view><view class="login-card data-v-b237504c"><view class="wx-info data-v-b237504c"><button class="avatar-btn data-v-b237504c" open-type="chooseAvatar" data-event-opts="{{[['chooseavatar',[['onChooseAvatar',['$event']]]]]}}" bindchooseavatar="__e"><block wx:if="{{avatarUrl}}"><image class="wx-avatar data-v-b237504c" src="{{avatarUrl}}" mode="aspectFill"></image></block><block wx:else><text class="avatar-placeholder data-v-b237504c">📷</text></block></button><view class="wx-name-box data-v-b237504c"><input class="nickname-input data-v-b237504c" type="nickname" placeholder="点击获取微信昵称" data-event-opts="{{[['input',[['__set_model',['','nickname','$event',[]]]]]]}}" value="{{nickname}}" bindinput="__e"/><text class="wx-tip data-v-b237504c">选填，可跳过直接登录</text></view></view><view class="agree-row data-v-b237504c"><checkbox style="transform:scale(0.7);" checked="{{agreed}}" color="#FF6B35" data-event-opts="{{[['tap',[['e0',['$event']]]]]}}" bindtap="__e" class="data-v-b237504c"></checkbox><text class="agree-text data-v-b237504c">我已阅读并同意</text><text data-event-opts="{{[['tap',[['goPrivacy',['$event']]]]]}}" class="agree-link data-v-b237504c" catchtap="__e">《用户服务协议及隐私政策》</text></view><button class="wx-auth-btn data-v-b237504c" loading="{{loading}}" disabled="{{loading||!agreed}}" data-event-opts="{{[['tap',[['handleWechatAuth',['$event']]]]]}}" bindtap="__e"><text class="wx-icon data-v-b237504c">💬</text><text class="data-v-b237504c">{{loading?'登录中...':'微信授权登录'}}</text></button><text class="bottom-tip data-v-b237504c">首次使用点击授权即自动注册</text><view data-event-opts="{{[['tap',[['goHome',['$event']]]]]}}" class="back-link data-v-b237504c" bindtap="__e"><text class="data-v-b237504c">返回首页</text></view></view></view>