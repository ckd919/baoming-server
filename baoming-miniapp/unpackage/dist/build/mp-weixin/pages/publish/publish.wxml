<view class="page data-v-30951268"><block wx:if="{{activity}}"><view class="status-card data-v-30951268"><text class="status-icon data-v-30951268">{{activity.status==='published'?'✅':'📦'}}</text><text class="status-text data-v-30951268">{{activity.status==='published'?'已发布':'待发布'}}</text><view class="stats data-v-30951268"><view class="stat-item data-v-30951268"><text class="stat-val data-v-30951268">{{$root.g0}}</text><text class="stat-lbl data-v-30951268">字段</text></view><view class="stat-item data-v-30951268"><text class="stat-val data-v-30951268">{{activity.submissionCount||0}}</text><text class="stat-lbl data-v-30951268">已报名</text></view><view class="stat-item data-v-30951268"><text class="stat-val data-v-30951268">{{activity.maxParticipants||'∞'}}</text><text class="stat-lbl data-v-30951268">上限</text></view></view></view></block><block wx:if="{{activity}}"><view class="card data-v-30951268"><text class="card-title data-v-30951268">📎 报名链接</text><view class="url-box data-v-30951268"><text class="url-text data-v-30951268">{{formUrl}}</text><button data-event-opts="{{[['tap',[['copyUrl',['$event']]]]]}}" class="btn-outline btn-sm data-v-30951268" bindtap="__e">复制</button></view><view class="qr-wrap data-v-30951268"><image style="width:320rpx;" src="{{qrUrl}}" mode="widthFix" class="data-v-30951268"></image></view><text class="hint data-v-30951268">微信扫码即可报名</text></view></block><block wx:if="{{activity}}"><view class="card data-v-30951268"><text class="card-title data-v-30951268">分享设置</text><view class="flex-row data-v-30951268"><text class="data-v-30951268">允许他人分享该报名</text><switch checked="{{activity.allowShare!==false}}" color="#D4720D" data-event-opts="{{[['change',[['toggleShare',['$event']]]]]}}" bindchange="__e" class="data-v-30951268"></switch></view><text class="hint data-v-30951268" style="margin-top:8rpx;">{{''+(activity.allowShare!==false?'好友可将报名链接转发到微信群、朋友圈':'仅管理员可分享，他人无法转发')+''}}</text></view></block><block wx:if="{{activity}}"><view class="card data-v-30951268"><block wx:if="{{activity.status!=='published'}}"><button data-event-opts="{{[['tap',[['publishNow',['$event']]]]]}}" class="btn-primary btn-block data-v-30951268" bindtap="__e">🚀 立即发布</button></block><block wx:else><button data-event-opts="{{[['tap',[['unpublish',['$event']]]]]}}" class="btn-block data-v-30951268" style="background:#f5f5f5;color:#999;border:none;" bindtap="__e">取消发布</button></block></view></block></view>